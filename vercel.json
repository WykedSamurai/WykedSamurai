{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/projects/fabled-compass.html",
      "destination": "https://fabled-compass.vercel.app/",
      "permanent": false
    },
    {
      "source": "/projects/fabled-compass",
      "destination": "https://fabled-compass.vercel.app/",
      "permanent": false
    }
  ]
}
